<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Avora.Views.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Avora.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Avora.Views.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d">
    <ScrollView>
        <StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <StackPanel.Resources>
                <Style TargetType="Border">
                    <Setter Property="Margin" Value="5,5,5,0" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="CornerRadius" Value="4" />
                    <Setter Property="Background" Value="{ThemeResource LayerFillColorAltBrush}" />
                    <Setter Property="Padding" Value="14" />
                </Style>
                <Style TargetType="Expander">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </StackPanel.Resources>

            <!-- Общие настройки -->
            <Expander Margin="0,0,0,8" IsExpanded="False" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon VerticalAlignment="Center" FontSize="16" Glyph="&#xE8F1;" />
                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Общие настройки" />
                    </StackPanel>
                </Expander.Header>
                <Expander.Content>
                    <StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Spacing="8">
                        <Border>
                            <local:StartUpSetting AutomationProperties.HelpText="Включает или выключает автоматический запуск приложения при старте системы" AutomationProperties.Name="Добавить приложение в автозагрузку" />
                        </Border>
                        <Border>
                            <local:HideToTraySetting AutomationProperties.HelpText="Скрывает приложение в системный трей вместо полного закрытия при нажатии на кнопку закрытия" AutomationProperties.Name="Скрывать в трей при закрытии" />
                        </Border>
                        <Border>
                            <local:CreateDesktopShortcut AutomationProperties.HelpText="Создает ярлык приложения на рабочем столе" AutomationProperties.Name="Создать ярлык на рабочем столе" />
                        </Border>
                        <Border>
                            <StackPanel Orientation="Horizontal">
                                <local:CheckUpdate AutomationProperties.HelpText="Проверяет наличие новых версий приложения" AutomationProperties.Name="Проверить обновления" />
                                <TextBlock Margin="15,0,0,0" VerticalAlignment="Center" AutomationProperties.HelpText="Отображает текущую версию приложения" AutomationProperties.Name="Текст текущей версии">
                                    Текущая версия:
                                </TextBlock>
                                <local:AppVersionText Margin="15,0,0,0" VerticalAlignment="Center" AutomationProperties.HelpText="Отображает текущую версию приложения" AutomationProperties.Name="Версия приложения" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Expander.Content>
            </Expander>

            <!-- Загрузка и управление музыкой -->
            <Expander Margin="0,0,0,8" IsExpanded="False" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon VerticalAlignment="Center" FontSize="16" Glyph="&#xE896;" />
                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Загрузка и управление музыкой" />
                    </StackPanel>
                </Expander.Header>
                <Expander.Content>
                    <StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Spacing="8">
                        <Border>
                            <local:DownloadAllSetting AutomationProperties.HelpText="Автоматически запускает параллельное скачивание всех плейлистов" AutomationProperties.Name="Запускать параллельное скачивание автоматически" />
                        </Border>
                        <Border>
                            <local:StartAllTaskSetting AutomationProperties.HelpText="Автоматически запускает все задачи скачивания при запуске приложения" AutomationProperties.Name="Запускать все таски автоматически" />
                        </Border>
                        <Border>
                            <local:DeleteAllAudioProfile AutomationProperties.HelpText="Удаляет все аудиозаписи из вашего профиля ВКонтакте" AutomationProperties.Name="Удалить все аудио из профиля" />
                        </Border>
                        <Border>
                            <local:ArchivateTracks AutomationProperties.HelpText="Архивирует все аудиозаписи в вашем профиле, перенося их в автоматически созданные плейлисты" AutomationProperties.Name="Заархивировать треки профиля" />
                        </Border>
                    </StackPanel>
                </Expander.Content>
            </Expander>

            <!-- Воспроизведение и аудио -->
            <Expander Margin="0,0,0,8" IsExpanded="False" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon VerticalAlignment="Center" FontSize="16" Glyph="&#xE8D6;" />
                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Воспроизведение и аудио" />
                    </StackPanel>
                </Expander.Header>
                <Expander.Content>
                    <StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Spacing="8">
                        <Border>
                            <local:UseFfmpegForPlaybackSetting AutomationProperties.HelpText="Включает или выключает использование FFMPEG для декодирования аудио" AutomationProperties.Name="Использовать FFMPEG для воспроизведения" />
                        </Border>
                      
                            <local:FfmpegSettingsExpander Margin="5" AutomationProperties.HelpText="Настройки параметров FFMPEG для воспроизведения аудио" AutomationProperties.Name="Настройки FFMPEG" />
                  
                    </StackPanel>
                </Expander.Content>
            </Expander>

            <!-- Кэш и память -->
            <Expander Margin="0,0,0,8" IsExpanded="False" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon VerticalAlignment="Center" FontSize="16" Glyph="&#xE8D5;" />
                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Кэш и память" />
                    </StackPanel>
                </Expander.Header>
                <Expander.Content>
                    <StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Spacing="8">
                        <Border>
                            <StackPanel>
                                <TextBlock AutomationProperties.HelpText="Отображает размер кеша для хранения фотографий" AutomationProperties.Name="Размер кеша фотографий" Text="Размер кеша фотографий" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <local:PhotoCacheSize x:Name="photocache" Grid.Column="0" AutomationProperties.HelpText="Регулирует размер кеша для хранения фотографий в мегабайтах" AutomationProperties.Name="Ползунок размера кеша фотографий" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" AutomationProperties.HelpText="Текущее значение размера кеша фотографий в мегабайтах" AutomationProperties.Name="Значение размера кеша фотографий" Text="{x:Bind photocache.Value, Mode=OneWay}" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" AutomationProperties.HelpText="Единицы измерения размера кеша фотографий" AutomationProperties.Name="Единицы измерения кеша фотографий" Text="МБ" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Expander.Content>
            </Expander>

            <Button Click="DebugConsole_Click" Margin="0,10,0,0" HorizontalAlignment="Stretch"
                    AutomationProperties.Name="Отладочная консоль">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon VerticalAlignment="Center" FontSize="16" Glyph="&#xE756;" />
                    <TextBlock VerticalAlignment="Center" Text="Отладочная консоль" />
                </StackPanel>
            </Button>

            <TextBlock Text="Avora v0.1.0 Alpha" FontSize="11" Opacity="0.4" HorizontalAlignment="Center" Margin="0,15,0,5"/>

        </StackPanel>
    </ScrollView>
</Page>