<?xml version="1.0" encoding="utf-8" ?>
<Expander
    x:Class="Avora.Views.Settings.FfmpegSettingsExpander"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Avora.Views.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Avora.Models"
    HorizontalAlignment="Stretch"
    HorizontalContentAlignment="Stretch"
    IsExpanded="False"
    mc:Ignorable="d">

    <Expander.Header>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <FontIcon
                VerticalAlignment="Center"
                FontSize="16"
                Glyph="&#xE8F2;" />
            <TextBlock
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                Text="Настройки FFMPEG" />
        </StackPanel>
    </Expander.Header>

    <Expander.Content>
        <StackPanel Spacing="12" HorizontalAlignment="Stretch">

            <!--  Сообщение о загрузке  -->
            <ProgressRing
                x:Name="LoadingProgress"
                Width="40"
                Height="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsActive="True"
                Visibility="Collapsed" />

            <TextBlock
                x:Name="ErrorMessage"
                Foreground="{ThemeResource SystemErrorTextColor}"
                TextWrapping="Wrap"
                Visibility="Collapsed" />

            <!--  Список настроек с группировкой по категориям  -->
            <ItemsControl x:Name="SettingsContainer" ItemsSource="{x:Bind SettingsByCategory, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:CategorySettingsGroup">
                        <Expander
                            Margin="0,0,0,8"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Header="{x:Bind CategoryName}"
                            IsExpanded="True">
                            <ItemsControl ItemsSource="{x:Bind Settings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:FfmpegSettingItem">
                                        <Grid
                                            Margin="0,4,0,8"
                                            Padding="8"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!--  Ключ настройки  -->
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontWeight="SemiBold"
                                                Text="{x:Bind Key}" />

                                            <!--  Описание  -->
                                            <TextBlock
                                                Grid.Row="1"
                                                Margin="0,4,0,8"
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind Description}"
                                                TextWrapping="Wrap" />

                                            <!--  Поле ввода и кнопка удаления  -->
                                            <Grid Grid.Row="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!--  Поле ввода значения с отслеживанием изменений  -->
                                                <TextBox
                                                    x:Name="ValueTextBox"
                                                    Grid.Column="0"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Center"
                                                    PlaceholderText="Введите значение..."
                                                    Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                <!--  Кнопка удаления (только для пользовательских настроек)  -->
                                                <Button
                                                    Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    Click="DeleteCustomSetting_Click"
                                                    Content="&#xE107;"
                                                    FontFamily="Segoe MDL2 Assets"
                                                    Style="{StaticResource DefaultButtonStyle}"
                                                    ToolTipService.ToolTip="Удалить настройку"
                                                    Visibility="{x:Bind IsCustom, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>

                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical" Spacing="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" Spacing="12" HorizontalAlignment="Stretch" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <!--  Панель управления  -->
            <Grid
                Margin="0,12,0,0"
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Поле для добавления новой настройки  -->
                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="NewSettingKey"
                        Grid.Column="0"
                        Margin="0,0,8,0"
                        PlaceholderText="Ключ новой настройки" />

                    <TextBox
                        x:Name="NewSettingValue"
                        Grid.Column="1"
                        Margin="0,0,8,0"
                        PlaceholderText="Значение" />

                    <Button
                        x:Name="AddButton"
                        Grid.Column="2"
                        Click="AddCustomSetting_Click"
                        Content="Добавить"
                        Style="{StaticResource AccentButtonStyle}" />
                </Grid>
            </Grid>

            <StackPanel Orientation="Horizontal">
                <!--  Кнопка сброса  -->
                <Button
                    x:Name="ResetButton"
                    Margin="12,0,12,0"
                    Click="ResetToDefaults_Click"
                    Content="Сбросить к стандартным"
                    Style="{StaticResource DefaultButtonStyle}"
                    ToolTipService.ToolTip="Вернуть все настройки к значениям по умолчанию" />
                <!--  Кнопка сохранения  -->
                <Button
                    x:Name="SaveButton"
                    Margin="10,0,0,0"
                    Click="SaveAllSettings_Click"
                    Content="Сохранить все"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTipService.ToolTip="Сохранить все изменения" />
            </StackPanel>

            <!--  Информационное сообщение  -->
            <Border
                Margin="0,8,0,0"
                Padding="12"
                Background="{ThemeResource InfoBarInformationalSeverityBackgroundBrush}"
                CornerRadius="4">
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="Информация о настройках FFMPEG" />
                    <TextBlock
                        FontSize="12"
                        Text="Изменения вступят в силу при следующем воспроизведении."
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

        </StackPanel>
    </Expander.Content>

    <Expander.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <x:Double x:Key="ExpanderContentThemePadding">12</x:Double>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Expander.Resources>

</Expander>