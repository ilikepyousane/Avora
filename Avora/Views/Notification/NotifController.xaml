<?xml version="1.0" encoding="utf-8" ?>
<UserControl
	x:Class="Avora.Views.Notification.NotifController"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="using:Avora.Views.Notification"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	DataContextChanged="UserControl_DataContextChanged"
	mc:Ignorable="d">

	<Grid
		x:Name="MainGrid"
		Padding="10"
		Background="{ThemeResource LayerOnAccentAcrylicFillColorDefaultBrush}"
		ColumnSpacing="10"
		CornerRadius="10"
		RowSpacing="0">
		<Grid.RowDefinitions>
			<RowDefinition Height="auto" />
			<RowDefinition Height="auto" />
			<RowDefinition Height="auto" />
			<RowDefinition Height="auto" />
			<RowDefinition Height="auto" />
			<RowDefinition Height="auto" />
			<RowDefinition Height="auto" />
		</Grid.RowDefinitions>

		<TextBlock
			x:Name="HeaderB"
			Grid.Row="0"
			Margin="0,0,0,10"
			HorizontalAlignment="Stretch"
			FontSize="20"
			TextWrapping="Wrap"
			Visibility="Collapsed" />
		<TextBlock
			x:Name="TextB"
			Grid.Row="1"
			Margin="0,0,0,10"
			HorizontalAlignment="Stretch"
			FontSize="14"
			TextWrapping="Wrap"
			Visibility="Collapsed" />
		<ContentControl
			x:Name="PageContent"
			Grid.Row="2"
			Margin="0,0,0,10"
			HorizontalAlignment="Stretch"
			VerticalAlignment="Stretch"
			Visibility="Collapsed" />

		<!-- Поле ввода для опросников -->
		<StackPanel
			x:Name="InputPanel"
			Grid.Row="3"
			Margin="0,0,0,10"
			Visibility="Collapsed"
			Spacing="5">
			<TextBox
				x:Name="InputTextBox"
				PlaceholderText="Введите ответ"
				HorizontalAlignment="Stretch"
				TextWrapping="Wrap"
				AcceptsReturn="True"
				MaxHeight="100"
				Visibility="Collapsed"/>
			<Button
				x:Name="SubmitInputButton"
				Content="Отправить"
				HorizontalAlignment="Stretch"
				Click="SubmitInputButton_Click"
				Visibility="Collapsed"/>
		</StackPanel>

		<!-- Динамические кнопки -->
		<ItemsControl
			x:Name="ButtonsItemsControl"
			Grid.Row="4"
			Margin="0,0,0,10"
			HorizontalAlignment="Stretch"
			Visibility="Collapsed">
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<StackPanel Orientation="Vertical" Spacing="5"/>
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>
			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<Button
						Content="{Binding Text}"
						HorizontalAlignment="Stretch"
						Click="DynamicButton_Click"
						Tag="{Binding}"/>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>

		<!-- Кнопка "Не хочу отвечать" -->
		<Button
			x:Name="DismissButton"
			Grid.Row="5"
			HorizontalAlignment="Stretch"
			Margin="0,0,0,10"
			Click="DismissButton_Click"
			Visibility="Collapsed">
			Не хочу отвечать
		</Button>

		<!-- Кнопка закрытия -->
		<Button
			Grid.Row="6"
			HorizontalAlignment="Stretch"
			Click="Button_Click">
			Закрыть
		</Button>
	</Grid>
</UserControl>
