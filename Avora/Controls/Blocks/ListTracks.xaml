<UserControl
    x:Class="Avora.Controls.Blocks.ListTracks"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:custom="using:Avora.Controls"
    xmlns:customV="using:Avora.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Avora.Controls.Blocks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Margin="0,0,0,0"
    mc:Ignorable="d">

    <customV:UniversalControl
        x:Name="myControl"
        ItemsSource="{x:Bind sectionAudio.listAudio}"
        itsAll="{x:Bind sectionAudio.itsAll}"
        AutomationProperties.Name="Список треков">
        <customV:UniversalControl.ItemsPanelTemplate>
            <ItemsPanelTemplate>
                <ItemsWrapGrid MaximumRowsOrColumns="3" Orientation="Vertical" />
            </ItemsPanelTemplate>
        </customV:UniversalControl.ItemsPanelTemplate>
        <customV:UniversalControl.ItemTemplate>
            <DataTemplate>
                <custom:TrackControl
                    x:Name="trControl"
                    MaxWidth="400"
                    MinWidth="300"
                    FocusVisualPrimaryBrush="Transparent"
                    FocusVisualSecondaryThickness="0" />
            </DataTemplate>
        </customV:UniversalControl.ItemTemplate>
    </customV:UniversalControl>
</UserControl>
