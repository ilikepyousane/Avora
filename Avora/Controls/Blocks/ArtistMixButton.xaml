<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Avora.Controls.Blocks.ArtistMixButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:custom="using:Avora.Helpers.Animations"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Avora.Controls.Blocks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="200"
    Height="220"
    Margin="3,0,4,6"
    CornerRadius="8"
    PointerEntered="UserControl_PointerEntered"
    PointerExited="UserControl_PointerExited"
    PointerPressed="UserControl_PointerPressed"
    Translation="0,0,8"
    mc:Ignorable="d">

    <UserControl.Shadow>
        <ThemeShadow />
    </UserControl.Shadow>

    <Grid Background="{ThemeResource LayerOnAccentAcrylicFillColorDefaultBrush}" CornerRadius="8">
        <Grid.Resources>
            <!--  Анимация прозрачности от 0 до 1  -->
            <Storyboard x:Name="FadeInAnimationGridPlayIcon">
                <DoubleAnimation
                    Storyboard.TargetName="btnGrid"
                    Storyboard.TargetProperty="Opacity"
                    To="1"
                    Duration="0:0:0.25" />
            </Storyboard>
            <!--  Анимация прозрачности от 1 до 0  -->
            <Storyboard x:Name="FadeOutAnimationGridPlayIcon">
                <DoubleAnimation
                    Storyboard.TargetName="btnGrid"
                    Storyboard.TargetProperty="Opacity"
                    To="0"
                    Duration="0:0:0.25" />
            </Storyboard>

        </Grid.Resources>

        <Grid>
            <FontIcon Glyph="&#xE90B;" AutomationProperties.Name="Обложка плейлиста" />
            <Grid
                x:Name="fadeOp"
                Background="{ThemeResource LayerOnAccentAcrylicFillColorDefaultBrush}"
                Opacity="1">
                <custom:GridImagesCustom x:Name="GridThumbs" AutomationProperties.Name="Изображения плейлиста">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                </custom:GridImagesCustom>
                <custom:GridImagesCustom VerticalAlignment="Bottom" Margin="0,0,-20,-30" CornerRadius="100" Width="150" Height="150"     
                                      x:Name="GridThumbsForeground" AutomationProperties.Name="Изображения плейлиста">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                </custom:GridImagesCustom>
            </Grid>
        </Grid>

        <Grid Padding="10">
            <StackPanel HorizontalAlignment="Left" Orientation="Vertical">
                <TextBlock
                    x:Name="TitleText"
                    FontSize="20"
                    Text="{Binding Title}"
                    TextWrapping="Wrap"
                    AutomationProperties.Name="Название плейлиста" />
                <TextBlock
                    x:Name="DescriptionText"
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding Description}"
                    AutomationProperties.Name="Описание плейлиста" />
            </StackPanel>

            <SymbolIcon
                Width="24"
                Height="24"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Symbol="List"
                AutomationProperties.Name="Иконка списка" />
            <Grid
                x:Name="btnGrid"
                Width="50"
                Height="50"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="{ThemeResource SystemControlBackgroundAltMediumHighBrush}"
                CornerRadius="100"
                Opacity="0">
                <Button
                    Width="50"
                    Height="50"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="Button_Click"
                    CornerRadius="50"
                    Opacity="1"
                    Translation="0,0,8">
                    <FontIcon
                        x:Name="PlayPause"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Glyph="&#xF5B0;"
                        AutomationProperties.Name="Кнопка воспроизведения" />
                </Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>