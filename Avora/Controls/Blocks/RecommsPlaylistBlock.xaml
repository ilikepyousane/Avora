<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Avora.Controls.Blocks.RecommsPlaylistBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:custom="using:Avora.Controls"
    xmlns:customV="using:Avora.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Avora.Controls.Blocks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Margin="0,0,0,0"
    mc:Ignorable="d"
        AutomationProperties.Name="Блок рекомендованных плейлистов">

    <UserControl.Resources />
    <UserControl.Shadow>
        <ThemeShadow />
    </UserControl.Shadow>


    <customV:UniversalControl
        x:Name="myControl"
        ItemsSource="{x:Bind playlists}"
        itsAll="{x:Bind itsAll}"
        AutomationProperties.Name="Список рекомендованных плейлистов">
     
        <customV:UniversalControl.ItemTemplate>
            <DataTemplate>
                <custom:RecommsPlaylist
                    x:Name="trControl"
                    FocusVisualPrimaryBrush="Transparent"
                    FocusVisualSecondaryThickness="0" />
            </DataTemplate>
        </customV:UniversalControl.ItemTemplate>
    </customV:UniversalControl>
</UserControl>
